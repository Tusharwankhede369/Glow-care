NODE_ENV=development
PORT=5000
# IMPORTANT: keep DB name casing consistent on Windows
MONGODB_URI=mongodb://127.0.0.1:27017/Glowcare
JWT_SECRET=replace_me_with_a_strong_secret

# Comma-separated
